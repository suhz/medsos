# Medsos — copy to .env (mode 0600, gitignored) and fill in.
MEDSOS_DB_URL=sqlite:///./medsos.db
MEDSOS_MASTER_KEY=                  # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MEDSOS_THREADS_META_APP_ID=
MEDSOS_THREADS_META_APP_SECRET=
MEDSOS_WEBHOOK_VERIFY_TOKEN=        # any random string you also paste into the Meta dashboard
MEDSOS_CALLBACK_URL_BASE=           # e.g. https://medsos.example.com
MEDSOS_PUBLISH_WAIT=30

# Optional (local-image hosting):
# MEDSOS_SHARE_DIR=/var/lib/medsos/share
# MEDSOS_SHARE_URL_BASE=https://medsos.example.com/share
